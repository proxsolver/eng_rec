# ============================================================
# 영어 학습 녹음기 설정
# 이 파일만 수정하면 됩니다!
# ============================================================

# --- 텔레그램 ---
BOT_TOKEN = 여기에_봇토큰_입력
CHAT_ID   = 여기에_챗아이디_입력

# --- 스트림 URL (수정 필요 없음) ---
FM_STREAM  = https://ebsonair.ebs.co.kr/fmradiofamilypc/familypc1m/playlist.m3u8
AOD_STREAM   = http://ebsonairiosaod.ebs.co.kr/fmradiobandiaod/bandiappaac/playlist.m3u8

# --- 녹음 폴더 ---
RECORDINGS_DIR = ./recordings

# --- 프로그램 스케줄 ---
# 형식: 이름 | 시작(KST) | 종료(KST) | 요일 | 정규/재방송 | 소스(FM/AOD)
# 요일: MON-FRI, MON-SAT, ALL, MON,WED,FRI 등
# 재방송은 본방송 녹음 실패 시에만 녹음됩니다
#
Easy Writing         | 05:59 | 06:22 | MON-SAT | 정규  | FM
Easy Writing 재방송  | 09:00 | 09:23 | MON-SAT | 재방송 | AOD_STREAM
입이 트이는 영어      | 06:20 | 06:40 | MON-SAT | 정규  | FM
입이 트이는 영어 재방송 | 09:20 | 09:40 | MON-SAT | 재방송 | AOD_STREAM
최수진의 모닝스페셜  | 08:00 | 08:20 | ALL     | 정규  | FM

# 프로그램 추가하려면 아래 줄의 #을 지우세요:
#새 프로그램 | 10:00 | 10:30 | MON-FRI | 정규 | FM
